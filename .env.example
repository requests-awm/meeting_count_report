# --- Google Calendar (service account + domain-wide delegation) ---
# Path to the downloaded service-account JSON key file.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
# An admin/user to fall back to if a calendar has no explicit subject.
GOOGLE_IMPERSONATE_SUBJECT=operations.support@ascotwm.com

# --- Asana ---
# Personal Access Token from https://app.asana.com/0/my-apps
ASANA_PAT=
# Workspace GID (optional if project GIDs are set).
ASANA_WORKSPACE_GID=
# Comma-separated Asana project GIDs that hold the meeting tasks.
ASANA_PROJECT_GIDS=
